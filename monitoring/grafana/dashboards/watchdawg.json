{
  "uid": "watchdawg-overview",
  "title": "Watchdawg",
  "tags": ["watchdawg"],
  "timezone": "browser",
  "schemaVersion": 38,
  "version": 1,
  "refresh": "10s",
  "time": { "from": "now-1h", "to": "now" },
  "panels": [
    {
      "id": 1,
      "type": "stat",
      "title": "Check Health",
      "gridPos": { "x": 0, "y": 0, "w": 24, "h": 4 },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "orientation": "auto",
        "textMode": "auto",
        "colorMode": "background",
        "graphMode": "none"
      },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": 0 },
              { "color": "green", "value": 1 }
            ]
          },
          "mappings": [
            {
              "type": "value",
              "options": {
                "0": { "text": "DOWN", "color": "red" },
                "1": { "text": "UP", "color": "green" }
              }
            }
          ]
        }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "watchdawg_check_up",
          "legendFormat": "{{check}}",
          "instant": true
        }
      ]
    },
    {
      "id": 2,
      "type": "timeseries",
      "title": "Check Executions / min",
      "description": "Rate of check executions broken down by check name and result (success/failure).",
      "gridPos": { "x": 0, "y": 4, "w": 12, "h": 8 },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": { "lineWidth": 2 }
        }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sum by (check, result) (rate(watchdawg_check_executions_total[1m])) * 60",
          "legendFormat": "{{check}} / {{result}}"
        }
      ]
    },
    {
      "id": 3,
      "type": "timeseries",
      "title": "Avg Check Duration",
      "description": "Average duration of each check execution.",
      "gridPos": { "x": 12, "y": 4, "w": 12, "h": 8 },
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "custom": { "lineWidth": 2 }
        }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "rate(watchdawg_check_duration_seconds_sum[2m]) / rate(watchdawg_check_duration_seconds_count[2m])",
          "legendFormat": "{{check}}"
        }
      ]
    },
    {
      "id": 4,
      "type": "timeseries",
      "title": "Check Success Rate",
      "description": "Fraction of executions that were healthy over the last 5 minutes.",
      "gridPos": { "x": 0, "y": 12, "w": 12, "h": 8 },
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "min": 0,
          "max": 1,
          "custom": { "lineWidth": 2 }
        }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sum by (check) (rate(watchdawg_check_executions_total{result=\"success\"}[5m])) / sum by (check) (rate(watchdawg_check_executions_total[5m]))",
          "legendFormat": "{{check}}"
        }
      ]
    },
    {
      "id": 5,
      "type": "timeseries",
      "title": "Kafka Message Age",
      "description": "Age of the most recently received Kafka message. Only populated for Kafka checks.",
      "gridPos": { "x": 12, "y": 12, "w": 12, "h": 8 },
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "custom": { "lineWidth": 2 }
        }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "watchdawg_check_message_age_seconds",
          "legendFormat": "{{check}}"
        }
      ]
    },
    {
      "id": 6,
      "type": "timeseries",
      "title": "Hook Executions / min",
      "description": "Rate of hook deliveries broken down by check, trigger (on_success/on_failure), and result.",
      "gridPos": { "x": 0, "y": 20, "w": 12, "h": 8 },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": { "lineWidth": 2 }
        }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sum by (check, trigger, result) (rate(watchdawg_hook_executions_total[1m])) * 60",
          "legendFormat": "{{check}} {{trigger}} / {{result}}"
        }
      ]
    },
    {
      "id": 7,
      "type": "timeseries",
      "title": "Avg Hook Duration",
      "description": "Average time spent delivering a hook.",
      "gridPos": { "x": 12, "y": 20, "w": 12, "h": 8 },
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "custom": { "lineWidth": 2 }
        }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "rate(watchdawg_hook_duration_seconds_sum[2m]) / rate(watchdawg_hook_duration_seconds_count[2m])",
          "legendFormat": "{{check}} {{trigger}}"
        }
      ]
    }
  ]
}
