{
  "healthchecks": [
    {
      "name": "dynamic_check",
      "type": "http",
      "schedule": "3s",
      "retries": 0,
      "timeout": 2000000000,
      "http": {
        "url": "http://integration-tests:8080/target/health",
        "method": "GET"
      },
      "on_success": [
        {
          "http": {
            "url": "http://integration-tests:9090/callback/success",
            "method": "POST"
          }
        }
      ],
      "on_failure": [
        {
          "http": {
            "url": "http://integration-tests:9090/callback/failure",
            "method": "POST"
          }
        }
      ]
    }
  ]
}
