{
  "healthchecks": [
    {
      "name": "dynamic_check",
      "type": "http",
      "schedule": "3s",
      "retries": 0,
      "timeout": 2000000000,
      "http": {
        "url": "http://integration-tests:8080/health",
        "method": "GET"
      },
      "on_success": {
        "url": "http://integration-tests:9090/success",
        "method": "POST"
      },
      "on_failure": {
        "url": "http://integration-tests:9090/failure",
        "method": "POST"
      }
    }
  ]
}
