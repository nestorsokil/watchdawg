{
  "metrics": {
    "address": ":9091"
  },
  "history": {
    "db_path": "/tmp/watchdawg-history.db",
    "retention": 1000,
    "record_all_healthchecks": true
  },
  "healthchecks": [
    {
      "name": "dynamic_check",
      "schedule": "3s",
      "retries": 0,
      "timeout": 2000000000,
      "record": true,
      "http": {
        "url": "http://integration-tests:8080/target/health/dynamic_check",
        "method": "GET"
      },
      "on_success": [
        {
          "http": {
            "url": "http://integration-tests:9090/callback/success",
            "method": "POST"
          }
        }
      ],
      "on_failure": [
        {
          "http": {
            "url": "http://integration-tests:9090/callback/failure",
            "method": "POST"
          }
        }
      ]
    },
    {
      "name": "multi_hook_check",
      "schedule": "3s",
      "retries": 0,
      "timeout": 2000000000,
      "http": {
        "url": "http://integration-tests:8080/target/health/multi_hook_check",
        "method": "GET"
      },
      "on_success": [
        {
          "http": {
            "url": "http://integration-tests:9090/callback/success",
            "method": "POST"
          }
        },
        {
          "http": {
            "url": "http://integration-tests:9090/callback/success",
            "method": "POST"
          }
        }
      ],
      "on_failure": [
        {
          "http": {
            "url": "http://integration-tests:9090/callback/failure",
            "method": "POST"
          }
        },
        {
          "http": {
            "url": "http://integration-tests:9090/callback/failure",
            "method": "POST"
          }
        }
      ]
    },
    {
      "name": "kafka_assertion",
      "schedule": "5s",
      "timeout": 10000000000,
      "kafka": {
        "brokers": ["kafka:9092"],
        "topic": "watchdawg-assertion-input",
        "group_id": "watchdawg-assertion",
        "format": "json",
        "assertion": "result['status'] == 'ok'"
      },
      "on_success": [
        {
          "http": {
            "url": "http://integration-tests:9090/callback/success",
            "method": "POST"
          }
        }
      ],
      "on_failure": [
        {
          "http": {
            "url": "http://integration-tests:9090/callback/failure",
            "method": "POST"
          }
        }
      ]
    },
    {
      "name": "grpc_server_health",
      "schedule": "3s",
      "retries": 0,
      "timeout": 2000000000,
      "grpc": {
        "target": "integration-tests:50051",
        "plaintext": true
      },
      "on_success": [
        {
          "http": {
            "url": "http://integration-tests:9090/callback/success",
            "method": "POST"
          }
        }
      ],
      "on_failure": [
        {
          "http": {
            "url": "http://integration-tests:9090/callback/failure",
            "method": "POST"
          }
        }
      ]
    },
    {
      "name": "grpc_service_health",
      "schedule": "3s",
      "retries": 0,
      "timeout": 2000000000,
      "grpc": {
        "target": "integration-tests:50051",
        "plaintext": true,
        "service": "integration.TestService"
      },
      "on_success": [
        {
          "http": {
            "url": "http://integration-tests:9090/callback/success",
            "method": "POST"
          }
        }
      ],
      "on_failure": [
        {
          "http": {
            "url": "http://integration-tests:9090/callback/failure",
            "method": "POST"
          }
        }
      ]
    },
    {
      "name": "kafka_liveness",
      "schedule": "5s",
      "timeout": 10000000000,
      "kafka": {
        "brokers": ["kafka:9092"],
        "topic": "watchdawg-target"
      },
      "on_success": [
        {
          "kafka": {
            "brokers": ["kafka:9092"],
            "topic": "watchdawg-success"
          }
        }
      ],
      "on_failure": [
        {
          "kafka": {
            "brokers": ["kafka:9092"],
            "topic": "watchdawg-failure"
          }
        }
      ]
    }
  ]
}
