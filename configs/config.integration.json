{
  "healthchecks": [
    {
      "name": "dynamic_check",
      "type": "http",
      "schedule": "3s",
      "retries": 0,
      "timeout": 2000000000,
      "http": {
        "url": "http://integration-tests:8080/target/health",
        "method": "GET"
      },
      "on_success": [
        {
          "http": {
            "url": "http://integration-tests:9090/callback/success",
            "method": "POST"
          }
        }
      ],
      "on_failure": [
        {
          "http": {
            "url": "http://integration-tests:9090/callback/failure",
            "method": "POST"
          }
        }
      ]
    },
    {
      "name": "kafka_liveness",
      "type": "kafka",
      "schedule": "5s",
      "timeout": 10000000000,
      "kafka": {
        "brokers": ["kafka:9092"],
        "topic": "watchdawg-target"
      },
      "on_success": [
        {
          "kafka": {
            "brokers": ["kafka:9092"],
            "topic": "watchdawg-success"
          }
        }
      ],
      "on_failure": [
        {
          "kafka": {
            "brokers": ["kafka:9092"],
            "topic": "watchdawg-failure"
          }
        }
      ]
    }
  ]
}
